# Copy this file to .env.local and fill in for production.
# Local dev does not need any of these — Keystatic uses the filesystem.

# Public: shown in the Keystatic admin UI
NEXT_PUBLIC_GITHUB_REPO_OWNER=
NEXT_PUBLIC_GITHUB_REPO_NAME=raina-lab
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Secrets for the Keystatic GitHub App (server-only).
# Get these from https://github.com/settings/apps after creating your app.
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
